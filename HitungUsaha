</head>


<body>


<div class="container">


<h1>HitungUsaha</h1>

<p>Aplikasi pencatat keuntungan usaha</p>



<label>Nama Produk</label>
<input id="produk" type="text" placeholder="Contoh: Kopi">



<label>Kategori</label>
