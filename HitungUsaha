Export Spreadsheet
</button>




<table id="riwayat">

<tr>

<th>Produk</th>
<th>Kategori</th>
<th>Stok</th>
<th>Modal/Pcs</th>
<th>Jual/Pcs</th>
<th>Jumlah</th>
<th>Total Modal</th>
<th>Total Jual</th>
<th>Untung</th>
<th>Tanggal</th>

</tr>


</table>


